[Unit]
Description=FlashSourceMap Global Data Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=flashgame
Group=flashgame
WorkingDirectory=/opt/flashSourceMap
Environment=NODE_ENV=production
Environment=GLOBAL_DATA_HOST=0.0.0.0
Environment=GLOBAL_DATA_PORT=8800
Environment=GLOBAL_DATA_DB=/var/lib/flash-global-data/global-game.db
ExecStart=/usr/bin/npm run globalData:serve
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
