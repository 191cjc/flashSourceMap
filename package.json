{
  "name": "flash-source-map",
  "version": "0.2.10",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "download": "tsx src/tools/downloadOriginals.ts",
    "extract": "tsx src/tools/extractInnerSwf.ts",
    "decompile": "bash tools/decompile.sh",
    "saveData:serve": "tsx runtime/save-data/server/server.ts",
    "saveData:test:db": "tsx runtime/save-data/tests/db-flow.test.ts",
    "native-flash:build-host": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/build-native-cef-host.ps1",
    "native-flash:build-launcher": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/build-native-package-launcher.ps1",
    "native-flash:prepare": "node tools/launch-native-flash-mock.cjs --prepare",
    "start:native-flash:mock": "node tools/launch-native-flash-mock.cjs",
    "native-flash:package": "node tools/package-native-flash.cjs"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^24.0.7",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@ruffle-rs/ruffle": "^0.4.0-nightly.2026.7.1",
    "crypto-js": "^4.2.0"
  }
}
